R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET_NAME=afterglowr-originals

# R2 source layout:
# originals/Animals/example_PC.png
# originals/Animals/example_MP.png
R2_PREFIX_ORIGINALS=originals
R2_PREFIX_THUMBNAILS=thumbnails
R2_CDN_BASE_URL=https://cdn.afterglowr.com

# Optional: where originals are downloaded while generating webp thumbnails.
# If omitted, the OS temp directory is used.
R2_SYNC_TMP_DIR=
